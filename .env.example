# =============================================================
# LabManager Pro — Variáveis de Ambiente
# Copie este arquivo: cp .env.example .env
# Preencha os valores marcados com ⚠
# =============================================================

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=labmanager
POSTGRES_USER=labmanager
POSTGRES_PASSWORD=labmanager123        # ⚠ troque em produção

# ── JWT / Segurança ───────────────────────────────────────────
# ⚠ OBRIGATÓRIO em produção — gere com:
# python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROQUE-ESTA-CHAVE-EM-PRODUCAO

ACCESS_TOKEN_EXPIRE_MINUTES=480        # 8 horas

# ── Portas ────────────────────────────────────────────────────
FRONTEND_PORT=8088                     # altere se a porta estiver em uso
